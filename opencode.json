{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "angular-cli": {
      "type": "local",
      "command": [
        "/usr/local/bin/npx",
        "-y",
        "@angular/cli",
        "mcp",
        "--experimental-tool"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "/usr/local/bin/npx",
        "@playwright/mcp@latest",
        "--headless"
      ]
    }
  }
}
